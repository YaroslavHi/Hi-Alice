# ============================================================
# HI Alice Adapter — Environment Configuration Template
# Copy to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://alice_svc:CHANGE_ME@postgres:5432/hi_cloud

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Uncomment and set if Redis requires a password:
# REDIS_PASSWORD=

# ── Yandex Developer Console ──────────────────────────────────
# From: dialogs.yandex.ru → your skill → OAuth settings
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Allowed OAuth redirect URIs (comma-separated).
# Default covers the standard Yandex Smart Home redirect.
YANDEX_REDIRECT_URI_ALLOWLIST=https://social.yandex.net/broker/redirect

# From: dialogs.yandex.ru → your skill → Skill ID
# Required for push notifications (only available after skill publication)
YANDEX_SKILL_ID=
# From: dialogs.yandex.ru → your skill → notification OAuth token
YANDEX_SKILL_OAUTH_TOKEN=

# ── HI Auth ───────────────────────────────────────────────────
# URL of the HI login page (where users authenticate with their house credentials)
# For testing, run the login stub from docs/DEPLOYMENT.md
HI_LOGIN_URL=https://alice.your-domain.com/login-stub

# ── Service URL ───────────────────────────────────────────────
# Public HTTPS base URL of this service — must match Yandex Dialogs webhook setting
# Do NOT add /v1.0 suffix — Yandex appends the path automatically
SERVICE_BASE_URL=https://alice.your-domain.com

# ── Token Security ────────────────────────────────────────────
# Two independent 64-hex-char (32-byte) keys. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AES-256-GCM key — encrypts tokens at rest
TOKEN_ENCRYPTION_KEY=
# HMAC-SHA256 key — fast lookup index (must differ from ENCRYPTION_KEY)
TOKEN_HMAC_KEY=

# ── P4 Relay ──────────────────────────────────────────────────
# Internal URL of the P4 relay service (Node-RED or custom relay)
# Examples:
#   Node-RED on same host:  http://nodered:1880
#   External relay:         http://p4-relay:4000
P4_RELAY_URL=http://nodered:1880
# Strong random secret shared between alice-adapter and P4 relay (min 32 chars)
P4_RELAY_TOKEN=

# ── Postgres credentials (used by docker-compose.yml) ─────────
POSTGRES_PASSWORD=CHANGE_ME

# ── Optional tuning ───────────────────────────────────────────
# Token TTLs (seconds)
# ACCESS_TOKEN_TTL_SECONDS=2592000     # 30 days
# REFRESH_TOKEN_TTL_SECONDS=7776000    # 90 days
# AUTH_CODE_TTL_SECONDS=600            # 10 minutes

# Rate limiting per IP per window
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# P4 relay request timeout
# P4_RELAY_TIMEOUT_MS=8000

# Logging: fatal | error | warn | info | debug | trace
# LOG_LEVEL=info

# Server port (default 3000, change if port is occupied)
# PORT=3000
