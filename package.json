{
  "name": "@hi-smartbox/alice-adapter",
  "version": "0.1.0",
  "description": "HI SmartBox – Yandex Smart Home API adapter (Cloud Control Plane)",
  "private": true,
  "engines": { "node": ">=20" },
  "scripts": {
    "build":    "tsc -p tsconfig.json",
    "start":    "node dist/index.js",
    "dev":      "tsx watch src/index.ts",
    "lint":     "eslint src --ext .ts",
    "test":     "vitest run",
    "test:cov": "vitest run --coverage",
    "migrate":  "node scripts/migrate.js",
    "migrate:dev": "node -r dotenv/config scripts/migrate.js"
  },
  "dependencies": {
    "fastify":                "^4.28.1",
    "@fastify/helmet":        "^11.1.1",
    "@fastify/rate-limit":    "^9.1.0",
    "@fastify/sensible":      "^5.6.0",
    "fastify-plugin":         "^4.5.1",
    "@fastify/redis":         "^6.1.1",
    "postgres":               "^3.4.4",
    "zod":                    "^3.23.8",
    "uuid":                   "^10.0.0",
    "nanoid":                 "^5.0.7",
    "argon2":                 "^0.41.1",
    "pino":                   "^9.4.0",
    "pino-pretty":            "^11.3.0",
    "dotenv":                 "^16.4.7"
  },
  "devDependencies": {
    "typescript":             "^5.5.4",
    "tsx":                    "^4.19.2",
    "vitest":                 "^2.1.8",
    "@types/node":            "^22.7.5",
    "@types/uuid":            "^10.0.0",
    "eslint":                 "^9.12.0",
    "@typescript-eslint/parser": "^8.8.1",
    "@typescript-eslint/eslint-plugin": "^8.8.1"
  }
}
